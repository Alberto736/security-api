MONGO_URI=mongodb://user:password@localhost:27017/hermod?authSource=hermod

# Optional NVD API key (recommended for better rate limits)
# NVD_API_KEY=

# API key de la empresa para proteger endpoints (/inventario).
# En producción configura un valor seguro y compártelo solo con clientes autorizados.
API_KEY=
API_KEY_HEADER=X-API-Key
API_KEY_REQUIRED=false

REQUEST_TIMEOUT_SECONDS=10
REQUEST_DELAY_SECONDS=0.35
