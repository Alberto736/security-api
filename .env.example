# Development environment configuration
# Copy this file to .env and update with your values

# Database Configuration
MONGO_URI=mongodb://user:password@localhost:27017/security_api?authSource=security_api
MONGO_DB=security_api
MONGO_INVENTORY_COLLECTION=inventory

# External API Keys (Optional but recommended)
NVD_API_KEY=
USER_AGENT=security-api/0.1.0

# Security Configuration
API_KEY=
API_KEY_HEADER=X-API-Key
API_KEY_REQUIRED=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false

# CORS Configuration
# For production, specify specific domains: ["https://yourcompany.com", "https://app.yourcompany.com"]
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# Request Configuration
REQUEST_TIMEOUT_SECONDS=10
REQUEST_DELAY_SECONDS=0.35
MAX_REQUEST_SIZE=10485760

# Environment Settings
ENVIRONMENT=development
DEBUG=false
